<Window x:Class="AppWatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppWatch" Height="560" Width="860"
        Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="AppWatch" FontSize="20" FontWeight="Bold" DockPanel.Dock="Left"/>
            <TextBlock x:Name="AdminStatusText" Text="管理者権限: 確認中"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Foreground="Gray"/>
        </DockPanel>

        <!-- 監視対象 EXE -->
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="監視対象 EXE:" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,8,0"/>
            <Button x:Name="BrowseButton" Content="参照..." Width="80" DockPanel.Dock="Right"
                    Margin="8,0,0,0" Click="BrowseButton_Click"/>
            <TextBox x:Name="TargetExeTextBox" VerticalContentAlignment="Center"
                     TextChanged="TargetExeTextBox_TextChanged"/>
        </DockPanel>

        <!-- トグル -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="監視:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ToggleButton x:Name="MonitorToggle" Width="70" Height="26" IsEnabled="False"
                          Checked="MonitorToggle_Checked" Unchecked="MonitorToggle_Unchecked">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="OFF"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="ON"/>
                                <Setter Property="Background" Value="#FFB6E7B0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <TextBlock Text="通信ブロック:" VerticalAlignment="Center" Margin="24,0,6,0"/>
            <ToggleButton x:Name="BlockToggle" Width="70" Height="26" IsEnabled="False"
                          Checked="BlockToggle_Checked" Unchecked="BlockToggle_Unchecked">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="OFF"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="ON"/>
                                <Setter Property="Background" Value="#FFF3B6B6"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <Button x:Name="ClearButton" Content="クリア" Width="80" Margin="24,0,0,0"
                    Click="ClearButton_Click"/>
        </StackPanel>

        <!-- イベントログ -->
        <ListView x:Name="LogListView" Grid.Row="3"
                  FontFamily="Consolas" FontSize="13"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="時刻" Width="90" DisplayMemberBinding="{Binding Time}"/>
                    <GridViewColumn Header="種別" Width="70" DisplayMemberBinding="{Binding Kind}"/>
                    <GridViewColumn Header="内容" Width="620" DisplayMemberBinding="{Binding Detail}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
